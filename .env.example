# Supabase
VITE_SUPERBASE_URL=
VITE_SUPERBASE_PUBLISH_KEY=

# Router: history (default) | hash — hash berguna tanpa rewrite server (mis. GitHub Pages)
# VITE_ROUTER_MODE=hash

# Base path untuk static host (GitHub Pages CI set otomatis ke /nama-repo/)
# VITE_BASE_PATH=/vuejs_with_supabase/

# Nomor WhatsApp untuk bukti pembayaran (format: 6281234567890)
VITE_PAYMENT_PROOF_WHATSAPP=
